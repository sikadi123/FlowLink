{
  "name": "flowlink-vue-client",
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "android:init": "npm.cmd install @capacitor/core @capacitor/cli @capacitor/android --save-dev && npx cap add android",
    "android:sync": "npm.cmd run build && npx cap sync android",
    "android:open": "npx cap open android"
  },
  "dependencies": {
    "@lucide/vue": "^1.18.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "pinia": "^2.2.6",
    "vite": "^8.0.16",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/cli": "^8.4.0",
    "@capacitor/core": "^8.4.0"
  }
}
